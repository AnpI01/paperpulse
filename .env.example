# Database (SQLite for local dev; swap to Postgres URL on Render)
DATABASE_URL=sqlite+aiosqlite:///./paperpulse.db

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Semantic Scholar (optional — raises rate limit from 10 to 100 req/sec)
SEMANTIC_SCHOLAR_API_KEY=

# Email
MY_EMAIL=your_email@gmail.com
APP_PASSWORD=your_gmail_app_password

# Recipients (comma-separated)
DIGEST_RECIPIENTS=your_email@gmail.com

# Paper fetch settings
ARXIV_CATEGORIES=cs.CL,cs.AI,cs.LG,cs.CV,cs.RO
MAX_PAPERS_PER_RUN=50
DAYS_LOOKBACK=1
